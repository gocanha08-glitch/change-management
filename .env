# Variaveis de ambiente - configure na Vercel (Settings > Environment Variables)
# NAO coloque valores reais aqui - este arquivo esta no GitHub publico

RESEND_API_KEY=your_resend_api_key_here
DEV_EMAIL=your_email_here
APP_URL=https://change-management-eta.vercel.app
DATABASE_URL=your_neon_database_url_here
JWT_SECRET=your_jwt_secret_here
SETUP_TOKEN=your_setup_token_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ENDPOINT=your_r2_endpoint_here
